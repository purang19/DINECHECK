rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Evaluators may submit surveys, but nobody can read/update/delete from the
    // client. Reads for reports run through a trusted/admin context.
    match /surveys/{survey} {
      allow create: if true;
      allow read, update, delete: if false;
    }
  }
}
