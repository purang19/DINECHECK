# Supabase backend that stores survey submissions. These are read at build time
# by Vite. The publishable/anon key is safe to expose in the client — access is
# controlled by row-level security (see supabase/migrations). If you omit these,
# the app falls back to the shared DINECHECK project defined in src/supabase.ts.
VITE_SUPABASE_URL="https://your-project-ref.supabase.co"
VITE_SUPABASE_ANON_KEY="your-publishable-or-anon-key"
